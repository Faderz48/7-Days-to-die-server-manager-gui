# Maintainer: You <you@example.com>
pkgname=sdtd-server-manager
pkgver=0.1.0
pkgrel=1
pkgdesc="Self-hosted web control panel for 7 Days to Die dedicated servers"
arch=('x86_64')
url="https://example.com/your-fork-or-source-here"
license=('MIT')
depends=('gtk3')
makedepends=('cargo')
# Point this at wherever your source archive lives. For local builds,
# you can replace the source array with `source=()` and run makepkg
# from inside an unpacked source tree.
source=()
sha256sums=()

prepare() {
    # If you're building from a checkout in the parent directory,
    # symlink it into $srcdir so build()/package() find it. Skipping
    # for the no-source-array case.
    :
}

build() {
    cd "${SRCDEST:-..}"
    cargo build --release --locked
}

package() {
    cd "${SRCDEST:-..}"
    install -Dm755 "target/release/sdtd-server-manager" \
        "$pkgdir/usr/bin/sdtd-server-manager"
    install -Dm644 "assets/icon-256.png" \
        "$pkgdir/usr/share/icons/hicolor/256x256/apps/sdtd-server-manager.png"
    install -Dm644 "packaging/sdtd-server-manager.desktop" \
        "$pkgdir/usr/share/applications/sdtd-server-manager.desktop"
    install -Dm644 "packaging/sdtd-server-manager.service" \
        "$pkgdir/usr/lib/systemd/user/sdtd-server-manager.service"
    install -Dm644 "README.md" \
        "$pkgdir/usr/share/doc/$pkgname/README.md"
    install -Dm644 "LICENSE" \
        "$pkgdir/usr/share/licenses/$pkgname/LICENSE" 2>/dev/null || true
}
